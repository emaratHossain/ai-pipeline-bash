# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT with: Issues (read/write), Pull Requests (read/write), Contents (read/write)
GITHUB_TOKEN=github_pat_...

# owner/repo — e.g. sakib/my-project
GITHUB_REPO=owner/repo-name

# Must match the secret set in GitHub repo Settings → Webhooks
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# GitHub username of the bot account whose token you use above
BOT_USERNAME=your-github-username

# Comma-separated list of GitHub usernames allowed to run /approve
# Leave empty to allow anyone who can comment on the issue
TRUSTED_USERS=your-github-username,teammate2

# ── Repository ────────────────────────────────────────────────────────────────
# Absolute path to the local clone of the repo the bot will edit
REPO_PATH=/absolute/path/to/your/repo

# Branch to base PRs against (default: main)
BASE_BRANCH=main

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── AI Provider ───────────────────────────────────────────────────────────────
# "anthropic"  — Anthropic API (default)
# "openrouter" — any model via openrouter.ai
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...

# Required when AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Tuning ────────────────────────────────────────────────────────────────────
# Override the default model (claude-sonnet-4-6 for Anthropic)
PIPELINE_MODEL=

# Max tokens for AI responses
MAX_TOKENS=4096

# Max bytes of repo context to pass to AI
MAX_CONTEXT_BYTES=40000

# Optional: custom system prompt for pipeline
# PIPELINE_SYSTEM_PROMPT=You are a senior WordPress plugin engineer. Focus on PHP and performance.

# ── Testing ───────────────────────────────────────────────────────────────────
# Set to true to skip AI calls and use canned responses
MOCK_MODE=false
